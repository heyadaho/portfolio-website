---
import { getCollection, render } from 'astro:content';
import CaseStudyLayout from '../../layouts/CaseStudyLayout.astro';
import CaseStudyHeader from '../../components/work/CaseStudyHeader.astro';
import OverviewBlock from '../../components/work/OverviewBlock.astro';
import CaseStudyFooter from '../../components/work/CaseStudyFooter.astro';
import ImageCarousel from '../../components/work/ImageCarousel.astro';

export async function getStaticPaths() {
  const entries = await getCollection('ai');
  const sorted  = entries.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

  return sorted.map((entry, i) => {
    const next = sorted[i + 1];
    return {
      params: { slug: entry.id },
      props: {
        entry,
        next: next
          ? { title: next.data.title, company: next.data.company, slug: next.id }
          : undefined,
      },
    };
  });
}

const { entry, next } = Astro.props;
const { Content } = await render(entry);

const {
  title, company, year, role, duration, summary,
  problem, approach, outcome, heroImages, image,
} = entry.data;

const hasOverview = problem && approach && outcome;
---

<CaseStudyLayout title={title} description={summary}>

  <CaseStudyHeader
    title={title}
    summary={summary}
    role={role}
    company={company}
    year={year}
    duration={duration}
    hideHeroImage={true}
  />

  {heroImages && heroImages.length > 0 ? (
    <div class="cs-carousel">
      <ImageCarousel images={heroImages} />
    </div>
  ) : image ? (
    <div class="cs-hero-image">
      <img src={image} alt={title} />
    </div>
  ) : null}

  {hasOverview && (
    <OverviewBlock
      problem={problem!}
      approach={approach!}
      outcome={outcome!}
    />
  )}

  <article class="cs-body">
    <Content />
  </article>

  <CaseStudyFooter next={next} />

</CaseStudyLayout>

<style>
  .cs-carousel {
    padding-inline: var(--space-md);
    max-width: var(--w-content);
    margin-inline: auto;
    padding-top: var(--space-lg);
  }

  .cs-hero-image {
    padding-inline: var(--space-md);
    max-width: var(--w-content);
    margin-inline: auto;
    padding-top: var(--space-lg);
  }

  .cs-hero-image img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 3px;
    border: 1px solid var(--c-border);
    display: block;
  }

  .cs-body {
    padding-block: var(--space-lg) 0;
  }

  .cs-body :global(p),
  .cs-body :global(li) {
    font-size: var(--text-md);
    font-weight: 300;
    color: var(--c-ink-mid);
    line-height: 1.75;
    max-width: 62ch;
  }

  .cs-body :global(h2),
  .cs-body :global(h3) {
    margin-top: 2.5em;
    margin-bottom: 0.75em;
  }

  .cs-body :global(h2) { font-size: var(--text-2xl); }
  .cs-body :global(h3) { font-size: var(--text-xl); }

  .cs-body :global(strong) {
    font-weight: 500;
    color: var(--c-ink);
  }

  .cs-body :global(a) {
    color: var(--c-accent);
    text-underline-offset: 3px;
    text-decoration: underline;
    text-decoration-color: var(--c-accent-dim);
    transition: text-decoration-color var(--dur-fast);
  }

  .cs-body :global(a:hover) {
    text-decoration-color: var(--c-accent);
  }

  .cs-body :global(blockquote) {
    margin-block: 1.4em;
    padding: 0.1em 0 0.1em 1.25rem;
    border-left: 2px solid var(--c-accent-dim);
  }

  .cs-body :global(blockquote p) {
    font-family: var(--font-display);
    font-size: var(--text-md);
    font-style: italic;
    color: var(--c-ink-mid);
    font-weight: 400;
    max-width: 58ch;
  }

  .cs-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    margin-block: 1.5em;
  }

  .cs-body :global(th) {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-accent);
    text-align: left;
    padding: 0.6em 1em 0.6em 0;
    border-bottom: 1px solid var(--c-border-strong);
  }

  .cs-body :global(td) {
    color: var(--c-ink-mid);
    font-weight: 300;
    padding: 0.65em 1em 0.65em 0;
    border-bottom: 1px solid var(--c-border);
    vertical-align: top;
  }

  .cs-body :global(tr:last-child td) {
    border-bottom: none;
  }

  .cs-body :global(hr) {
    border: none;
    border-top: 1px solid var(--c-border);
    margin-block: var(--space-lg);
  }
</style>
