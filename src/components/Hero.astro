---
---

<section class="hero" id="home">
  <canvas class="hero__canvas" id="landscape-canvas" aria-hidden="true"></canvas>

  <!-- Dissolve gradient — fades canvas into page background -->
  <div class="hero__dissolve" aria-hidden="true"></div>

  <div class="hero__content">
    <h1 class="hero__name">Ed Lake</h1>
    <div class="hero__meta">
      <span class="hero__title">Principal Product Designer</span>
      <span class="hero__rule" aria-hidden="true"></span>
      <span class="hero__open">Open to work</span>
    </div>
  </div>

  <div class="hero__scroll-cue" aria-hidden="true">
    <span class="hero__scroll-label">Scroll</span>
    <div class="hero__scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 600px;
    overflow: hidden;
  }

  .hero__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Fades the canvas into the page background colour */
  .hero__dissolve {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 38%,
      rgba(var(--c-base-rgb, 11, 20, 14), 0.40) 65%,
      var(--c-base) 100%
    );
    pointer-events: none;
    z-index: 2;
    transition: background var(--dur-slow) var(--ease-in-out);
  }

  /* ── Hero text ── */
  .hero__content {
    position: absolute;
    bottom: 13%;
    width: 100%;
    text-align: center;
    z-index: 10;
    padding-inline: 2rem;
    pointer-events: none;
  }

  .hero__name {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 0.92;
    color: rgba(240, 237, 232, 0.96);
    opacity: 0;
    animation: riseIn 1.6s var(--ease-expo) 0.5s forwards;
  }

  .hero__meta {
    margin-top: 1.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.4rem;
    opacity: 0;
    animation: riseIn 1.1s var(--ease-expo) 1.15s forwards;
  }

  .hero__title {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 400;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: rgba(240, 237, 232, 0.42);
  }

  .hero__rule {
    display: block;
    width: 1px;
    height: 14px;
    background: rgba(196, 168, 130, 0.28);
    flex-shrink: 0;
  }

  .hero__open {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: rgba(196, 168, 130, 0.85);
    border: 1px solid rgba(196, 168, 130, 0.28);
    padding: 0.3em 0.9em 0.28em;
    border-radius: 1px;
  }

  /* ── Scroll cue ── */
  .hero__scroll-cue {
    position: absolute;
    bottom: 3.5%;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 7px;
    pointer-events: none;
    opacity: 0;
    animation: fadeIn 1s ease 2.4s forwards;
  }

  .hero__scroll-label {
    font-family: var(--font-body);
    font-size: 0.58rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(240, 237, 232, 0.22);
  }

  .hero__scroll-line {
    width: 1px;
    height: 38px;
    background: linear-gradient(to bottom, rgba(196, 168, 130, 0.55), transparent);
    animation: linePulse 2.8s ease-in-out 2.9s infinite;
  }

  /* Light theme */
  :root[data-theme="light"] .hero__dissolve {
    background: linear-gradient(
      to bottom,
      transparent 38%,
      rgba(245, 243, 239, 0.50) 65%,
      #F5F3EF 100%
    );
  }

  :root[data-theme="light"] .hero__name {
    color: rgba(18, 26, 20, 0.92);
  }

  :root[data-theme="light"] .hero__title {
    color: rgba(18, 26, 20, 0.55);
  }

  :root[data-theme="light"] .hero__rule {
    background: rgba(18, 26, 20, 0.25);
  }

  :root[data-theme="light"] .hero__open {
    color: rgba(18, 26, 20, 0.80);
    border-color: rgba(18, 26, 20, 0.25);
  }

  :root[data-theme="light"] .hero__scroll-label {
    color: rgba(18, 26, 20, 0.40);
  }

  :root[data-theme="light"] .hero__scroll-line {
    background: linear-gradient(to bottom, rgba(18, 26, 20, 0.35), transparent);
  }

  @media (max-width: 480px) {
    .hero__rule { display: none; }
    .hero__meta { gap: 1rem; }
  }
</style>

<script is:inline>
(() => {
'use strict';

// ═══════════════════════════════════════════════════════
//  MATH UTILITIES
// ═══════════════════════════════════════════════════════

const lerp  = (a, b, t) => a + (b - a) * t;

function hash(n) {
  const s = Math.sin(n * 127.1 + 311.7) * 43758.5453123;
  return s - Math.floor(s);
}

function vnoise(x, seed) {
  const i = Math.floor(x);
  const f = x - i;
  const u = f * f * f * (f * (f * 6.0 - 15.0) + 10.0);
  return lerp(hash(i + seed * 137.317), hash(i + 1.0 + seed * 137.317), u);
}

function fbm(x, seed, octaves) {
  octaves = octaves || 7;
  let v = 0, amp = 0.52, freq = 1;
  for (let o = 0; o < octaves; o++) {
    v += amp * vnoise(x * freq, seed + o * 31.73);
    amp  *= 0.50;
    freq *= 1.98;
  }
  return v;
}

function warpedFbm(x, seed, scale) {
  const wx = fbm(x * scale * 0.38, seed + 500, 3) * 55.0;
  return fbm((x + wx) * scale, seed, 7);
}

function dome(h) {
  const c = h * 2.0 - 1.0;
  return 0.5 + 0.5 * Math.sign(c) * Math.pow(Math.abs(c), 0.62);
}

// ═══════════════════════════════════════════════════════
//  CANVAS
// ═══════════════════════════════════════════════════════

const canvas = document.getElementById('landscape-canvas');
if (!canvas) return;
const ctx = canvas.getContext('2d');
let W = 0, H = 0, DPR = 1;

// ── Parallax ──
const off = { x: 0, y: 0 };
const tgt = { x: 0, y: 0 };

window.addEventListener('mousemove', function(e) {
  tgt.x = (e.clientX / innerWidth  - 0.5) * 2;
  tgt.y = (e.clientY / innerHeight - 0.5) * 2;
});
window.addEventListener('touchmove', function(e) {
  tgt.x = (e.touches[0].clientX / innerWidth  - 0.5) * 2;
  tgt.y = (e.touches[0].clientY / innerHeight - 0.5) * 2;
}, { passive: true });

// ── Palette ──
var SKY_TOP = [88,  112, 122];
var SKY_MID = [138, 168, 178];
var SKY_LOW = [168, 195, 200];
var FOG_RGB = [168, 200, 210];

var LAYER_DEFS = [
  { id:'d0', s:7,  bY:0.46, am:0.090, rgb:[22, 42, 44],  px:0.009 },
  { id:'d1', s:13, bY:0.50, am:0.110, rgb:[26, 52, 54],  px:0.016 },
  { id:'d2', s:19, bY:0.55, am:0.135, rgb:[30, 68, 68],  px:0.026 },
  { id:'m0', s:29, bY:0.60, am:0.160, rgb:[36, 88, 76],  px:0.040 },
  { id:'m1', s:41, bY:0.66, am:0.185, rgb:[44, 106, 78], px:0.058 },
  { id:'m2', s:53, bY:0.71, am:0.205, rgb:[54, 118, 72], px:0.080 },
  { id:'n0', s:67, bY:0.77, am:0.225, rgb:[62, 128, 60], px:0.108 },
  { id:'fg', s:79, bY:0.85, am:0.235, rgb:[10, 22, 14],  px:0.165 },
];

var noiseScaleFor = function(bY) { return 0.00095 + bY * 0.00095; };

var WATER = {
  outer:  'rgba(20, 200, 195, 0.07)',
  mid:    'rgba(60, 230, 220, 0.22)',
  inner:  'rgba(120, 248, 240, 0.70)',
  bright: 'rgba(200, 255, 252, 0.95)',
};

// ── Scene data ──
const OVERRUN = 0.22;
const STEP    = 3;
var terrains  = {};
var spires    = [];
var mistPuffs = [];
var riverPts  = [];
var grainData = [];
var GRAIN_FRAMES = 6;
var GRAIN_RES    = 512;
var grainCanvas  = null;
var grainCtxG    = null;

function buildAll() {
  buildTerrains();
  buildSpires();
  buildMist();
  buildRiver();
  buildGrain();
}

function buildTerrains() {
  var extraW = W * OVERRUN;
  var startX = -extraW;
  var totalW = W + extraW * 2;
  var count  = Math.ceil(totalW / STEP) + 4;

  LAYER_DEFS.forEach(function(L) {
    var ns = noiseScaleFor(L.bY);
    var ys = new Float32Array(count);
    for (var i = 0; i < count; i++) {
      var x = startX + i * STEP;
      ys[i] = dome(warpedFbm(x, L.s, ns));
    }
    terrains[L.id] = { ys: ys, startX: startX, step: STEP };
  });
}

function buildSpires() {
  spires = [];
  var bands = [
    { bY:0.76, spread:0.030, count:48, scaleW:0.005, scaleH:0.034, s:200 },
    { bY:0.85, spread:0.022, count:32, scaleW:0.007, scaleH:0.048, s:400 },
  ];
  bands.forEach(function(b) {
    for (var i = 0; i < b.count; i++) {
      spires.push({
        x: hash(i * 13.1 + b.s) * W,
        y: (b.bY + (hash(i * 3.7 + b.s) - 0.5) * b.spread) * H,
        w: (0.3 + hash(i * 5.5 + b.s) * 0.7) * b.scaleW * W,
        h: (0.35 + hash(i * 11.3 + b.s) * 0.65) * b.scaleH * H,
        v: 0.55 + hash(i * 2.1 + b.s) * 0.45,
      });
    }
  });
}

function buildMist() {
  mistPuffs = [];
  for (var i = 0; i < 26; i++) {
    mistPuffs.push({
      cx:    hash(i * 9.3 + 1) * W,
      cy:    (0.40 + hash(i * 5.7 + 2) * 0.40) * H,
      rx:    (0.055 + hash(i * 3.3 + 3) * 0.195) * W,
      ry:    (0.010 + hash(i * 7.1 + 4) * 0.024) * H,
      alpha: 0.042 + hash(i * 11.7 + 5) * 0.092,
      spd:   (0.14 + hash(i * 2.9 + 6) * 0.30) * (hash(i * 17.3) > 0.5 ? 1 : -1),
      phase: hash(i * 6.3 + 7) * Math.PI * 2,
      depth: 0.25 + hash(i * 4.1 + 8) * 0.72,
    });
  }
}

function buildRiver() {
  riverPts = [];
  var SEG = 130;
  for (var i = 0; i <= SEG; i++) {
    var t     = i / SEG;
    // Gentle S-curve: dips slightly around t=0.38, rises gently through t=0.6-0.75
    var curve = Math.sin(t * Math.PI * 1.1 - 0.5) * W * 0.028;
    // Small organic kink in the middle-left zone only
    var kinkT = Math.max(0, 1 - Math.abs(t - 0.40) / 0.12);
    var kink  = Math.sin(t * Math.PI * 5.8 + 1.2) * W * 0.018 * kinkT * kinkT;
    // Very subtle noise for a hand-drawn feel
    var warp  = (fbm(t * 2.8, 999, 3) - 0.5) * W * 0.012;
    var sine1 = 0, sine2 = 0, bend1 = curve + kink, bend2 = 0;
    riverPts.push({
      x: W * (-0.14 + t * 1.28) + bend1 + warp,
      y: H * (0.67 + t * 0.07) + (fbm(t * 6, 888, 3) - 0.5) * H * 0.018,
    });
  }
}

function buildGrain() {
  grainData = [];
  var tmpCanvas = document.createElement('canvas');
  tmpCanvas.width = tmpCanvas.height = GRAIN_RES;
  var gc = tmpCanvas.getContext('2d');
  for (var f = 0; f < GRAIN_FRAMES; f++) {
    var id = gc.createImageData(GRAIN_RES, GRAIN_RES);
    for (var k = 0; k < id.data.length; k += 4) {
      var v = (Math.random() * 255) | 0;
      id.data[k] = id.data[k+1] = id.data[k+2] = v;
      id.data[k+3] = 18;
    }
    grainData.push(id);
  }
  grainCanvas = document.createElement('canvas');
  grainCanvas.width = grainCanvas.height = GRAIN_RES;
  grainCtxG = grainCanvas.getContext('2d');
}

// ── Drawing ──

function drawSky() {
  var g = ctx.createLinearGradient(0, 0, 0, H * 0.72);
  g.addColorStop(0.00, 'rgb(' + SKY_TOP + ')');
  g.addColorStop(0.45, 'rgb(' + SKY_MID + ')');
  g.addColorStop(1.00, 'rgb(' + SKY_LOW + ')');
  ctx.fillStyle = g;
  ctx.fillRect(0, 0, W, H);

  var ls = ctx.createRadialGradient(W*0.72, H*0.08, 0, W*0.72, H*0.08, W*0.55);
  ls.addColorStop(0.0, 'rgba(230,218,195,0.16)');
  ls.addColorStop(0.5, 'rgba(210,200,180,0.06)');
  ls.addColorStop(1.0, 'rgba(0,0,0,0)');
  ctx.fillStyle = ls;
  ctx.fillRect(0, 0, W, H * 0.65);
}

function drawTerrain(L, shiftX) {
  var td = terrains[L.id];
  if (!td) return;
  var ys = td.ys, startX = td.startX, step = td.step;
  var sx = shiftX * L.px * W;

  ctx.beginPath();
  var x0 = startX + sx;
  var y0 = L.bY * H - ys[0] * L.am * H;
  ctx.moveTo(x0, y0);

  for (var i = 1; i < ys.length; i++) {
    var x1 = startX + i * step + sx;
    var y1 = L.bY * H - ys[i] * L.am * H;
    ctx.quadraticCurveTo(x0, y0, (x0 + x1) * 0.5, (y0 + y1) * 0.5);
    x0 = x1; y0 = y1;
  }
  ctx.lineTo(x0, y0);
  ctx.lineTo(x0, H + 10);
  ctx.lineTo(startX + sx, H + 10);
  ctx.closePath();

  var r = L.rgb[0], g = L.rgb[1], b = L.rgb[2];
  var topY = L.bY * H - L.am * H;
  var tg = ctx.createLinearGradient(0, topY, 0, H);
  tg.addColorStop(0.0, 'rgb('+(r+14)+','+(g+14)+','+(b+12)+')');
  tg.addColorStop(0.3, 'rgb('+r+','+g+','+b+')');
  tg.addColorStop(1.0, 'rgb('+Math.max(0,r-8)+','+Math.max(0,g-8)+','+Math.max(0,b-8)+')');
  ctx.fillStyle = tg;
  ctx.fill();
}

function drawAtmosphericFog() {
  var fr = FOG_RGB[0], fg2 = FOG_RGB[1], fb = FOG_RGB[2];
  var g = ctx.createLinearGradient(0, 0, 0, H * 0.80);
  g.addColorStop(0.00, 'rgba('+fr+','+fg2+','+fb+',0.88)');
  g.addColorStop(0.20, 'rgba('+fr+','+fg2+','+fb+',0.60)');
  g.addColorStop(0.42, 'rgba('+fr+','+fg2+','+fb+',0.30)');
  g.addColorStop(0.62, 'rgba('+fr+','+fg2+','+fb+',0.09)');
  g.addColorStop(1.00, 'rgba('+fr+','+fg2+','+fb+',0.00)');
  ctx.fillStyle = g;
  ctx.fillRect(0, 0, W, H * 0.80);
}

function drawRiver(time, shiftX) {
  var sx  = shiftX * 0.082 * W;
  var pts = riverPts;
  if (pts.length < 3) return;

  var passes = [
    { lw:28,  alpha:0.05, color:WATER.outer  },
    { lw:18,  alpha:0.10, color:WATER.outer  },
    { lw:10,  alpha:0.20, color:WATER.mid    },
    { lw:5,   alpha:0.50, color:WATER.mid    },
    { lw:2.5, alpha:0.82, color:WATER.inner  },
    { lw:1.2, alpha:0.98, color:WATER.bright },
  ];

  passes.forEach(function(p) {
    ctx.save();
    ctx.beginPath();
    ctx.moveTo(pts[0].x + sx, pts[0].y);
    for (var i = 1; i < pts.length - 1; i++) {
      var t    = i / pts.length;
      var shim = Math.sin(time * 1.1 + t * 8.4) * 2.2
               + Math.sin(time * 0.5 + t * 3.7) * 1.1;
      var c = pts[i], n = pts[i + 1];
      ctx.quadraticCurveTo(
        c.x + sx, c.y + shim,
        (c.x + n.x) * 0.5 + sx, (c.y + n.y) * 0.5 + shim
      );
    }
    ctx.strokeStyle = p.color;
    ctx.globalAlpha = p.alpha;
    ctx.lineWidth   = p.lw;
    ctx.lineCap     = 'round';
    ctx.lineJoin    = 'round';
    if (p.lw > 8) {
      ctx.shadowColor = 'rgba(80,240,230,0.5)';
      ctx.shadowBlur  = p.lw * 1.8;
    }
    ctx.stroke();
    ctx.restore();
  });

  // Sparse moving lights along the river — groups of 1–3, long gaps between
  // 6 slots, each with a different base offset so they're staggered in time
  ctx.save();
  ctx.globalCompositeOperation = 'lighter';
  var SLOTS = [
    { seed: 0,    gap: 0.48, trail: 1    },   // solo
    { seed: 3.7,  gap: 0.55, trail: 2    },   // pair — second dot 0.018 behind
    { seed: 9.1,  gap: 0.62, trail: 1    },   // solo
    { seed: 15.3, gap: 0.70, trail: 3    },   // trio
    { seed: 21.8, gap: 0.58, trail: 1    },   // solo
    { seed: 28.4, gap: 0.65, trail: 2    },   // pair
  ];
  for (var s = 0; s < SLOTS.length; s++) {
    var slot = SLOTS[s];
    // t cycles 0→1 slowly; the gap parameter controls how much of the cycle
    // the dot is actually visible (rest of cycle = darkness between groups)
    var t = ((time * 0.055 + hash(slot.seed)) % 1.0);
    if (t > slot.gap) continue;          // in the dark gap, don't draw

    var progress = t / slot.gap;         // 0→1 across the visible window
    for (var d = 0; d < slot.trail; d++) {
      var tp = Math.max(0, progress - d * 0.018);
      var idx = Math.min((tp * (pts.length - 1)) | 0, pts.length - 2);
      var pt  = pts[idx];
      // fade leading dot bright, trail dots dimmer
      var a = (d === 0 ? 0.70 : d === 1 ? 0.35 : 0.18);
      ctx.fillStyle = 'rgba(190,255,250,' + a + ')';
      ctx.beginPath();
      ctx.arc(pt.x + sx, pt.y, 1.6 - d * 0.3, 0, Math.PI * 2);
      ctx.fill();
    }
  }
  ctx.restore();
}

function drawSpires(shiftX) {
  var sx = shiftX * 0.125 * W;
  ctx.save();
  spires.forEach(function(r) {
    var x  = r.x + sx;
    var vv = (r.v * 14) | 0;
    ctx.beginPath();
    ctx.moveTo(x,              r.y);
    ctx.lineTo(x - r.w*0.50,  r.y);
    ctx.lineTo(x - r.w*0.28,  r.y - r.h*0.38);
    ctx.lineTo(x - r.w*0.10,  r.y - r.h*0.72);
    ctx.lineTo(x - r.w*0.02,  r.y - r.h*0.90);
    ctx.lineTo(x,              r.y - r.h);
    ctx.lineTo(x + r.w*0.02,  r.y - r.h*0.90);
    ctx.lineTo(x + r.w*0.10,  r.y - r.h*0.72);
    ctx.lineTo(x + r.w*0.28,  r.y - r.h*0.38);
    ctx.lineTo(x + r.w*0.50,  r.y);
    ctx.closePath();
    ctx.fillStyle   = 'rgb(' + vv + ',' + (vv + 6) + ',' + (vv + 4) + ')';
    ctx.globalAlpha = 0.70;
    ctx.fill();
  });
  ctx.restore();
}

function drawMist(time, shiftX) {
  var mr = FOG_RGB[0], mg = FOG_RGB[1], mb = FOG_RGB[2];
  mistPuffs.forEach(function(p) {
    var drift   = Math.sin(time * p.spd * 0.11 + p.phase) * W * 0.048;
    var breathe = 0.65 + 0.35 * Math.sin(time * 0.22 + p.phase);
    var sx      = shiftX * p.depth * 0.032 * W;
    var cx      = p.cx + drift + sx;
    var a       = p.alpha * breathe;

    ctx.save();
    ctx.translate(cx, p.cy);
    ctx.scale(1.0, p.ry / p.rx);
    var g = ctx.createRadialGradient(0, 0, 0, 0, 0, p.rx);
    g.addColorStop(0.0, 'rgba('+mr+','+mg+','+mb+','+a+')');
    g.addColorStop(0.5, 'rgba('+mr+','+mg+','+mb+','+(a * 0.35)+')');
    g.addColorStop(1.0, 'rgba('+mr+','+mg+','+mb+',0)');
    ctx.fillStyle = g;
    ctx.beginPath();
    ctx.arc(0, 0, p.rx, 0, Math.PI * 2);
    ctx.fill();
    ctx.restore();
  });
}

function drawVignette() {
  var g = ctx.createRadialGradient(W*0.5, H*0.42, H*0.05, W*0.5, H*0.42, H*0.92);
  g.addColorStop(0.0, 'rgba(0,0,0,0)');
  g.addColorStop(0.7, 'rgba(0,0,0,0.06)');
  g.addColorStop(1.0, 'rgba(0,0,0,0.42)');
  ctx.fillStyle = g;
  ctx.fillRect(0, 0, W, H);
}

function drawGrade() {
  var g = ctx.createLinearGradient(0, 0, 0, H);
  g.addColorStop(0.00, 'rgba(72,104,120,0.08)');
  g.addColorStop(0.40, 'rgba(0,0,0,0)');
  g.addColorStop(0.85, 'rgba(0,0,0,0)');
  g.addColorStop(1.00, 'rgba(6,12,8,0.55)');
  ctx.fillStyle = g;
  ctx.fillRect(0, 0, W, H);
}

function drawGrain(frameIdx) {
  if (!grainData.length || !grainCanvas) return;
  grainCtxG.putImageData(grainData[frameIdx % GRAIN_FRAMES], 0, 0);
  ctx.save();
  ctx.globalCompositeOperation = 'overlay';
  ctx.globalAlpha = 0.038;
  var ox = (frameIdx * 19) % GRAIN_RES;
  var oy = (frameIdx * 13) % GRAIN_RES;
  for (var gx = -GRAIN_RES; gx < W + GRAIN_RES; gx += GRAIN_RES)
    for (var gy = -GRAIN_RES; gy < H + GRAIN_RES; gy += GRAIN_RES)
      ctx.drawImage(grainCanvas, gx + ox, gy + oy);
  ctx.restore();
}

// ── Animation loop ──

var t0 = null, frame = 0;

function tick(ts) {
  if (!t0) t0 = ts;
  var t = (ts - t0) * 0.001;
  frame++;

  off.x = lerp(off.x, tgt.x, 0.038);
  off.y = lerp(off.y, tgt.y, 0.038);

  ctx.clearRect(0, 0, W, H);

  drawSky();

  for (var i = 0; i < LAYER_DEFS.length - 2; i++)
    drawTerrain(LAYER_DEFS[i], off.x);

  drawAtmosphericFog();
  drawTerrain(LAYER_DEFS[LAYER_DEFS.length - 2], off.x);
  drawRiver(t, off.x);
  drawSpires(off.x);
  drawMist(t, off.x);
  drawTerrain(LAYER_DEFS[LAYER_DEFS.length - 1], off.x);
  drawVignette();
  drawGrade();
  drawGrain(frame / 3 | 0);

  requestAnimationFrame(tick);
}

// ── Init / resize ──

function resize() {
  DPR          = Math.min(window.devicePixelRatio || 1, 2);
  W            = canvas.clientWidth;
  H            = canvas.clientHeight;
  canvas.width  = (W * DPR) | 0;
  canvas.height = (H * DPR) | 0;
  ctx.scale(DPR, DPR);
  buildAll();
}

var resizeTimer;
window.addEventListener('resize', function() {
  clearTimeout(resizeTimer);
  resizeTimer = setTimeout(resize, 120);
});

resize();
requestAnimationFrame(tick);

})();
</script>
