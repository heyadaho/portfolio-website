---
const photoSrc = '/images/ed-lake.png';
---

<section class="about section" id="about">
  <div class="container">
    <div class="about__inner">

      <span class="label about__label">About</span>

      <div class="about__body">

        <div class="about__top">
          <div class="about__photo-wrap">
            <img
              src={photoSrc}
              alt="Ed Lake"
              class="about__photo"
              width="96"
              height="96"
              loading="lazy"
            />
          </div>

          <div class="about__text-group">
            <div class="about__bio">
              <p class="about__text">
                Product design leader with 15 years across travel, ecommerce, and B2B.
                I've built teams, founded design functions, and shipped work that moves
                commercial metrics at scale.
              </p>
              <p class="about__text">
                I care about craft and strategy in equal measure. Good systems make both
                better. The quality of the work matters as much as the outcome it drives.
              </p>
              <p class="about__text">
                Currently Principal Product Designer at loveholidays, leading design
                across web and app, the design system, and AI-assisted prototyping.
              </p>
            </div>
          </div>
        </div>

      </div>

    </div>
  </div>


</section>

<style>
  .about--no-bottom {
    padding-bottom: 0;
  }

  .about__inner {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 2rem 5rem;
    align-items: start;
    max-width: 900px;
  }

  .about__label {
    padding-top: 0.35rem;
  }

  .about__body {
    border-top: 1px solid var(--c-border);
    padding-top: 2rem;
  }

  /* ── Layout ── */
  .about__top {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
  }

  .about__photo-wrap {
    flex-shrink: 0;
  }

  .about__photo {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    border: 1px solid var(--c-border-strong);
    filter: grayscale(100%);
    display: block;
    transition: filter var(--dur-slow) var(--ease-in-out);
  }

  .about__photo:hover {
    filter: grayscale(60%);
  }

  .about__text-group {
    flex: 1;
  }

  .about__text {
    font-size: var(--text-md);
    font-weight: 300;
    color: var(--c-ink-mid);
    line-height: 1.75;
    max-width: 60ch;
  }

  .about__text + .about__text {
    margin-top: 1.1em;
  }

  /* ── Responsive ── */
  @media (max-width: 680px) {
    .about__inner {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .about__body {
      padding-top: 1.5rem;
    }

    .marquee-block {
      margin-top: 2.5rem;
    }
  }

  @media (max-width: 480px) {
    .about__top {
      flex-direction: column;
      gap: 1.5rem;
    }
  }
</style>
