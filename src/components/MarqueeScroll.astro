---
const lines = [
  {
    text: "This site is built around my love of the Welsh and Japanese countryside. The quiet, the space, the feeling of time stretching out as you move through the landscape.",
    duration: 80,
    lang: 'en',
  },
  {
    text: "Mae'r wefan hon wedi'i hadeiladu o amgylch fy nghariad at gefn gwlad Cymru a Japan. Y tawelwch, y gofod, y teimlad o amser yn ymestyn wrth i chi symud drwy'r tirwedd.",
    duration: 90,
    lang: 'cy',
  },
  {
    text: "このサイトはウェールズと日本の田舎への愛を中心に作られています。静けさ、空間、風景の中を移動するにつれて時間が伸びていく感覚。",
    duration: 70,
    lang: 'ja',
  },
];

// Very faint shadow — transparent enough to not compete with primary text
const c1 = 'rgba(196,168,130,0.13)';
const c2 = 'rgba(196,168,130,0.08)';
const c3 = 'rgba(196,168,130,0.04)';
const c4 = 'rgba(196,168,130,0.02)';
const c5 = 'rgba(196,168,130,0.005)';

function makeShadow(a: string, b: string, c: string, d: string, e: string) {
  const bands = [a, b, c, d, e];
  const parts: string[] = [];
  for (let band = 0; band < 5; band++) {
    const col = bands[band];
    for (let i = 1; i <= 20; i++) {
      const n = band * 20 + i;
      parts.push(`${Math.round(n * 0.15)}px ${n}px 0 ${col}`);
    }
  }
  return parts.join(',');
}

const s0 = makeShadow(c1,c2,c3,c4,c5);
const s1 = makeShadow(c2,c3,c4,c5,c1);
const s2 = makeShadow(c3,c4,c5,c1,c2);
const s3 = makeShadow(c4,c5,c1,c2,c3);
const s4 = makeShadow(c5,c1,c2,c3,c4);
---

<style set:html={`
  @keyframes marquee-shadow-shift {
    0%,100% { text-shadow: ${s0}; }
    20%     { text-shadow: ${s1}; }
    40%     { text-shadow: ${s2}; }
    60%     { text-shadow: ${s3}; }
    80%     { text-shadow: ${s4}; }
  }
`}></style>

<div class="marquee-wrap">
  <div class="marquee-fade marquee-fade--left"   aria-hidden="true"></div>
  <div class="marquee-fade marquee-fade--right"  aria-hidden="true"></div>
  <div class="marquee-fade marquee-fade--bottom" aria-hidden="true"></div>

  <div class="marquee-block" aria-hidden="true">
    {lines.map((line, li) => (
      <div class="marquee-row">

        {/* Ghost layer — blurred, transparent, carries the shadow + wave */}
        <div
          class="marquee-track marquee-track--ghost"
          style={`--dur: ${line.duration}s; --wave-delay: ${li * 3.2}s`}
          lang={line.lang}
          aria-hidden="true"
        >
          <span class="marquee-content marquee-content--ghost">{line.text}&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>
          <span class="marquee-content marquee-content--ghost">{line.text}&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>
        </div>

        {/* Primary layer — crisp and legible, on top */}
        <div
          class="marquee-track marquee-track--primary"
          style={`--dur: ${line.duration}s`}
          lang={line.lang}
        >
          <span class="marquee-content marquee-content--primary">{line.text}&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>
          <span class="marquee-content marquee-content--primary" aria-hidden="true">{line.text}&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>
        </div>

      </div>
    ))}
  </div>
</div>

<style>
  .marquee-wrap {
    position: relative;
    width: 100%;
    overflow: clip;
    border-top: 1px solid var(--c-border);
  }

  .marquee-fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 20%;
    z-index: 10;
    pointer-events: none;
  }

  .marquee-fade--left {
    left: 0;
    background: linear-gradient(to right, var(--c-base) 0%, transparent 100%);
  }

  .marquee-fade--right {
    right: 0;
    background: linear-gradient(to left, var(--c-base) 0%, transparent 100%);
  }

  .marquee-fade--bottom {
    bottom: 0;
    left: 0;
    right: 0;
    top: auto;
    width: 100%;
    height: 80px;
    background: linear-gradient(to bottom, transparent 0%, var(--c-base) 100%);
  }

  .marquee-block {
    width: 100%;
    padding-block: 1.75rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .marquee-row {
    position: relative;
    white-space: nowrap;
    height: 1.7em;
  }

  /* Both tracks sit in the same row space */
  .marquee-track {
    position: absolute;
    top: 0;
    left: 0;
    display: inline-flex;
    will-change: transform;
    animation: marquee-scroll var(--dur, 80s) linear infinite;
  }

  /* Ghost: behind, blurred, with deep shadow and a slow wave pulse */
  .marquee-track--ghost {
    z-index: 0;
    filter: blur(1.5px);
    animation:
      marquee-scroll var(--dur, 80s) linear infinite,
      marquee-wave 12s ease-in-out var(--wave-delay, 0s) infinite;
  }

  .marquee-content--ghost {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 300;
    letter-spacing: 0.01em;
    color: transparent; /* invisible — only the shadow shows */
    white-space: nowrap;
    animation: marquee-shadow-shift 28s ease-in-out infinite;
  }

  /* Primary: sharp, clearly readable, in front */
  .marquee-track--primary {
    z-index: 1;
  }

  .marquee-content--primary {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 300;
    letter-spacing: 0.01em;
    color: var(--c-ink-mid);
    white-space: nowrap;
    opacity: 0.82;
  }

  .marquee-track[lang="ja"] .marquee-content {
    font-size: var(--text-base);
    letter-spacing: 0.04em;
  }

  /* Wind wave: gently lifts and fades each row's shadow, offset per row */
  @keyframes marquee-wave {
    0%, 100% { opacity: 1;    transform: translateX(0)    translateY(0);    }
    25%       { opacity: 0.55; transform: translateX(4px)  translateY(-2px); }
    50%       { opacity: 0.85; transform: translateX(-2px) translateY(1px);  }
    75%       { opacity: 0.45; transform: translateX(6px)  translateY(-1px); }
  }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: marquee-scroll var(--dur, 80s) linear infinite; }
    .marquee-track--ghost { display: none; }
    .marquee-content--ghost { animation: none; }
  }
</style>
