---
interface AdjacentStudy {
  title: string;
  company: string;
  slug: string;
}

interface Props {
  prev?: AdjacentStudy;
  next?: AdjacentStudy;
  base?: string;
}

const { prev, next, base = '/work' } = Astro.props;
---

<footer class="cs-footer">
  <div class="container">

    <div class="cs-footer__top">
      <a href="/#work" class="cs-footer__back">
        <span class="label cs-footer__back-label">
          <span aria-hidden="true">←</span> All work
        </span>
      </a>
    </div>

    {(prev || next) && (
      <div class="cs-footer__inner">
        {prev ? (
          <a href={`${base}/${prev.slug}`} class="cs-footer__adj cs-footer__prev">
            <span class="label cs-footer__adj-label">
              <span aria-hidden="true">←</span> Previous
            </span>
            <span class="cs-footer__adj-title">{prev.title}</span>
            <span class="cs-footer__adj-company label">{prev.company}</span>
          </a>
        ) : <span aria-hidden="true"></span>}

        {next && (
          <a href={`${base}/${next.slug}`} class="cs-footer__adj cs-footer__next">
            <span class="label cs-footer__adj-label">
              Next <span aria-hidden="true">→</span>
            </span>
            <span class="cs-footer__adj-title">{next.title}</span>
            <span class="cs-footer__adj-company label">{next.company}</span>
          </a>
        )}
      </div>
    )}

  </div>
</footer>

<style>
  .cs-footer {
    padding-block: var(--space-xl) var(--space-lg);
    margin-top: var(--space-xl);
    border-top: 1px solid var(--c-border);
  }

  .cs-footer__top {
    margin-bottom: 2rem;
  }

  .cs-footer__back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--c-ink-subtle);
    transition: color var(--dur-fast);
  }

  .cs-footer__back:hover {
    color: var(--c-ink-mid);
  }

  .cs-footer__inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
  }

  .cs-footer__adj {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: opacity var(--dur-fast);
    max-width: 380px;
  }

  .cs-footer__next {
    align-items: flex-end;
    text-align: right;
    margin-left: auto;
  }

  .cs-footer__adj:hover {
    opacity: 0.8;
  }

  .cs-footer__adj-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--c-ink);
    line-height: 1.2;
  }

  .cs-footer__adj-company {
    color: var(--c-accent);
  }

  @media (max-width: 560px) {
    .cs-footer__inner {
      flex-direction: column;
    }

    .cs-footer__next {
      align-items: flex-start;
      text-align: left;
      margin-left: 0;
    }
  }
</style>
