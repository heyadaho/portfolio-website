---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats: Stat[];
  label?: string;
}

const { stats, label } = Astro.props;
---

<div class="stats-block">
  <div class="container">
    {label && <p class="stats-block__label label">{label}</p>}
    <div class="stats-block__grid">
      {stats.map(stat => (
        <div class="stats-block__item">
          <p class="stats-block__value">{stat.value}</p>
          <p class="stats-block__desc">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .stats-block {
    padding-block: var(--space-lg);
    border-bottom: 1px solid var(--c-border);
    margin-bottom: var(--space-lg);
  }

  .stats-block__label {
    margin-bottom: 1.5rem;
  }

  .stats-block__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem 2rem;
  }

  .stats-block__item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .stats-block__value {
    font-family: var(--font-display);
    font-size: clamp(8rem, 14vw, 12rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--c-accent);
  }

  .stats-block__desc {
    font-size: 0.65rem;
    font-weight: 300;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-ink-subtle);
    line-height: 1.5;
    max-width: 18ch;
  }

  @media (max-width: 768px) {
    .stats-block__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem 2rem;
    }
  }

  @media (max-width: 400px) {
    .stats-block__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
