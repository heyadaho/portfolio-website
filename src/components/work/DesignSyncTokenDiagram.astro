---
// No props — self-contained diagram
---

<figure class="dst">

  <div class="dst__header">
    <span class="dst__eyebrow label">4-Tier Token Architecture</span>
  </div>

  <div class="dst__tiers">

    <!-- Tier 1 -->
    <div class="dst__tier dst__tier--1">
      <div class="dst__tier-header">
        <span class="dst__tier-num">Tier 1</span>
        <div>
          <p class="dst__tier-name">Primitives <span class="dst__tier-sub">Core</span></p>
          <p class="dst__tier-desc">Raw brand values. Human-defined, one per brand.</p>
        </div>
      </div>
      <div class="dst__tokens">
        <div class="dst__token-group">
          <span class="dst__brand-pill dst__brand-pill--lh">loveholidays</span>
          <code class="dst__token">core.primary</code><span class="dst__eq">=</span><span class="dst__val">#0374DA</span>
        </div>
        <div class="dst__token-group">
          <span class="dst__brand-pill dst__brand-pill--hp">holidaypirates</span>
          <code class="dst__token">core.primary</code><span class="dst__eq">=</span><span class="dst__val">#B10038</span>
        </div>
        <div class="dst__token-group">
          <code class="dst__token">core.discount</code><span class="dst__eq">=</span><span class="dst__val">#DE2A5C</span>
        </div>
      </div>
    </div>

    <div class="dst__arrow">
      <span class="dst__arrow-label">auto-generates</span>
      <svg width="12" height="16" viewBox="0 0 12 16" fill="none"><path d="M6 0v13M1 9l5 6 5-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>

    <!-- Tier 2 -->
    <div class="dst__tier dst__tier--2">
      <div class="dst__tier-header">
        <span class="dst__tier-num">Tier 2</span>
        <div>
          <p class="dst__tier-name">Palette <span class="dst__tier-sub">Auto-generated</span></p>
          <p class="dst__tier-desc">Mathematical shade ramp from each primitive. Light (L10–L95) and Dark (D10–D95). Not used directly by components.</p>
        </div>
      </div>
      <div class="dst__tokens">
        <div class="dst__token-group">
          <code class="dst__token">palette.primary.light.L60</code>
        </div>
        <div class="dst__token-group">
          <code class="dst__token">palette.primary.dark.D80</code>
        </div>
      </div>
    </div>

    <div class="dst__arrow">
      <span class="dst__arrow-label">curates</span>
      <svg width="12" height="16" viewBox="0 0 12 16" fill="none"><path d="M6 0v13M1 9l5 6 5-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>

    <!-- Tier 3 -->
    <div class="dst__tier dst__tier--3">
      <div class="dst__tier-header">
        <span class="dst__tier-num">Tier 3</span>
        <div>
          <p class="dst__tier-name">Semantic <span class="dst__tier-sub">Brand selections</span></p>
          <p class="dst__tier-desc">Curated selections that define how colours are used. Reduces complexity — only the meaningful shades.</p>
        </div>
      </div>
      <div class="dst__tokens">
        <div class="dst__token-group">
          <code class="dst__token">brand.primary.base</code><span class="dst__ref">→ {"{"}core.primary{"}"}</span>
        </div>
        <div class="dst__token-group">
          <code class="dst__token">state.success.lighter</code><span class="dst__ref">→ {"{"}palette.success.light.L80{"}"}</span>
        </div>
        <div class="dst__token-group">
          <code class="dst__token">state.success.base</code><span class="dst__ref">→ {"{"}core.success{"}"}</span>
        </div>
        <div class="dst__token-group">
          <code class="dst__token">state.success.dark</code><span class="dst__ref">→ {"{"}palette.success.dark.D60{"}"}</span>
        </div>
      </div>
    </div>

    <div class="dst__arrow">
      <span class="dst__arrow-label">consumed by</span>
      <svg width="12" height="16" viewBox="0 0 12 16" fill="none"><path d="M6 0v13M1 9l5 6 5-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>

    <!-- Tier 4 -->
    <div class="dst__tier dst__tier--4">
      <div class="dst__tier-header">
        <span class="dst__tier-num">Tier 4</span>
        <div>
          <p class="dst__tier-name">Component <span class="dst__tier-sub">Specific</span></p>
          <p class="dst__tier-desc">Component-level tokens. What Figma and code consume. Name = documentation.</p>
        </div>
      </div>
      <div class="dst__tokens">
        <div class="dst__token-group">
          <code class="dst__token dst__token--long">ds.badge.product.accent.soft.default.background</code><span class="dst__ref">→ {"{"}brand.accent.lighter{"}"}</span>
        </div>
        <div class="dst__token-group">
          <code class="dst__token dst__token--long">ds.badge.state.success.base.default.foreground</code><span class="dst__ref">→ {"{"}surface.white{"}"}</span>
        </div>
        <div class="dst__token-group">
          <code class="dst__token dst__token--long">ds.button.primary.base.hover.background</code><span class="dst__ref">→ {"{"}brand.primary.dark{"}"}</span>
        </div>
      </div>
    </div>

  </div>

  <!-- Rule card -->
  <div class="dst__rule">
    <p class="dst__rule-heading">The key constraint</p>
    <p class="dst__rule-body">Components never reference Tier 1 or Tier 2 directly — always through the semantic layer. Switching brands (loveholidays → Holiday Pirates) only requires changing Tier 1. Everything else cascades automatically.</p>
  </div>

  <!-- Pipeline -->
  <div class="dst__pipeline">
    <span class="dst__pipeline-label label">Pipeline</span>
    <div class="dst__pipeline-steps">
      {["Figma", "Token Studio", "Git", "Style Dictionary", "Panda CSS / Tailwind / CSS vars"].map((step, i, arr) => (
        <span class="dst__pipeline-row">
          <span class="dst__pipeline-step">{step}</span>
          {i < arr.length - 1 && <span class="dst__pipeline-arrow" aria-hidden="true">→</span>}
        </span>
      ))}
    </div>
  </div>

  <figcaption class="dst__caption">
    Tier 1–3: fully defined for loveholidays + Holiday Pirates. Tier 4: Button (945 variants) and Badge (123 tokens).
  </figcaption>

</figure>

<style>
  .dst {
    margin-block: var(--space-lg);
    border: 1px solid var(--c-border);
    border-radius: 2px;
    background: var(--c-surface);
    max-width: var(--w-content);
    margin-inline: auto;
    overflow: hidden;
  }

  .dst__header {
    padding: 1.25rem 1.75rem 0;
  }

  .dst__eyebrow {
    color: var(--c-accent);
  }

  .dst__tiers {
    padding: 1.25rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Tier card */
  .dst__tier {
    border: 1px solid var(--c-border);
    border-radius: 2px;
    overflow: hidden;
  }

  .dst__tier-header {
    display: flex;
    gap: 1rem;
    padding: 0.9rem 1.1rem;
    border-bottom: 1px solid var(--c-border);
    align-items: flex-start;
  }

  .dst__tier-num {
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--c-ink-subtle);
    white-space: nowrap;
    padding-top: 0.15rem;
    min-width: 3.5rem;
  }

  .dst__tier-name {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--c-ink);
    line-height: 1.3;
    margin-bottom: 0.2rem;
  }

  .dst__tier-sub {
    font-weight: 300;
    color: var(--c-ink-subtle);
    font-size: 0.75rem;
  }

  .dst__tier-desc {
    font-size: 0.72rem;
    color: var(--c-ink-subtle);
    line-height: 1.5;
    font-weight: 300;
  }

  .dst__tokens {
    padding: 0.75rem 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .dst__token-group {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .dst__token {
    font-family: 'SF Mono', 'Fira Mono', monospace;
    font-size: 0.68rem;
    color: var(--c-ink);
    background: var(--c-surface-raised);
    border: 1px solid var(--c-border);
    padding: 0.15em 0.5em;
    border-radius: 2px;
  }

  .dst__token--long {
    font-size: 0.62rem;
  }

  .dst__eq {
    font-size: 0.65rem;
    color: var(--c-ink-subtle);
  }

  .dst__val {
    font-family: 'SF Mono', 'Fira Mono', monospace;
    font-size: 0.68rem;
    color: var(--c-accent);
  }

  .dst__ref {
    font-size: 0.62rem;
    color: var(--c-ink-subtle);
    font-family: 'SF Mono', 'Fira Mono', monospace;
  }

  .dst__brand-pill {
    font-size: 0.58rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.15em 0.5em;
    border-radius: 20px;
    font-weight: 500;
  }

  .dst__brand-pill--lh {
    background: rgba(3, 116, 218, 0.15);
    color: #0374DA;
    border: 1px solid rgba(3, 116, 218, 0.3);
  }

  .dst__brand-pill--hp {
    background: rgba(177, 0, 56, 0.12);
    color: #B10038;
    border: 1px solid rgba(177, 0, 56, 0.3);
  }

  /* Tier accent colours */
  .dst__tier--1 { border-color: rgba(3, 116, 218, 0.25); }
  .dst__tier--1 .dst__tier-num { color: #0374DA; }
  .dst__tier--2 { border-color: var(--c-border); }
  .dst__tier--3 { border-color: color-mix(in srgb, var(--c-accent) 35%, transparent); }
  .dst__tier--3 .dst__tier-num { color: var(--c-accent); }
  .dst__tier--4 { border-color: color-mix(in srgb, var(--c-accent) 60%, transparent); }
  .dst__tier--4 .dst__tier-num { color: var(--c-accent); }

  /* Arrow connector */
  .dst__arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    padding: 0.4rem 0;
    color: var(--c-ink-subtle);
  }

  .dst__arrow-label {
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .dst__arrow svg {
    opacity: 0.4;
  }

  /* Rule card */
  .dst__rule {
    margin: 0 1.75rem 1.25rem;
    padding: 1rem 1.25rem;
    border: 1px solid color-mix(in srgb, var(--c-accent) 30%, transparent);
    border-radius: 2px;
    background: color-mix(in srgb, var(--c-accent) 5%, var(--c-surface));
  }

  .dst__rule-heading {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-accent);
    font-weight: 500;
    margin-bottom: 0.4rem;
  }

  .dst__rule-body {
    font-size: 0.78rem;
    color: var(--c-ink-mid);
    line-height: 1.6;
    font-weight: 300;
  }

  /* Pipeline */
  .dst__pipeline {
    margin: 0 1.75rem 1.5rem;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .dst__pipeline-label {
    color: var(--c-ink-subtle);
    padding-top: 0.1rem;
    flex-shrink: 0;
  }

  .dst__pipeline-steps {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .dst__pipeline-row {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .dst__pipeline-step {
    font-family: 'SF Mono', 'Fira Mono', monospace;
    font-size: 0.65rem;
    color: var(--c-ink-mid);
    background: var(--c-surface-raised);
    border: 1px solid var(--c-border);
    padding: 0.2em 0.55em;
    border-radius: 2px;
  }

  .dst__pipeline-arrow {
    font-size: 0.65rem;
    color: var(--c-ink-subtle);
  }

  .dst__caption {
    padding: 0.9rem 1.75rem;
    border-top: 1px solid var(--c-border);
    font-size: var(--text-sm);
    color: var(--c-ink-subtle);
    line-height: 1.55;
  }

  @media (max-width: 600px) {
    .dst__tiers,
    .dst__rule,
    .dst__pipeline {
      padding-inline: 1rem;
      margin-inline: 0;
    }
    .dst__header { padding-inline: 1rem; }
    .dst__token--long { font-size: 0.55rem; }
    .dst__caption { padding-inline: 1rem; }
  }
</style>
