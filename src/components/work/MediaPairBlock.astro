---
interface Props {
  caption?: string;
  srcLeft?: string;
  srcRight?: string;
  altLeft?: string;
  altRight?: string;
}

const { caption, srcLeft, srcRight, altLeft = '', altRight = '' } = Astro.props;
---

<figure class="media-pair">
  <div class="media-pair__grid">
    <div class="media-pair__frame">
      {srcLeft ? (
        <img src={srcLeft} alt={altLeft} loading="lazy" />
      ) : (
        <div class="media-pair__placeholder" aria-hidden="true">
          <span class="label">Image</span>
        </div>
      )}
    </div>
    <div class="media-pair__frame">
      {srcRight ? (
        <img src={srcRight} alt={altRight} loading="lazy" />
      ) : (
        <div class="media-pair__placeholder" aria-hidden="true">
          <span class="label">Image</span>
        </div>
      )}
    </div>
  </div>

  {caption && (
    <figcaption class="media-pair__caption">{caption}</figcaption>
  )}
</figure>

<style>
  .media-pair {
    max-width: var(--w-content);
    margin-inline: auto;
    margin-block: var(--space-lg);
    padding-inline: var(--space-md);
  }

  .media-pair__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .media-pair__frame {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 2px;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
  }

  .media-pair__frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .media-pair__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--c-surface-raised), var(--c-surface));
  }

  .media-pair__caption {
    margin-top: 0.9rem;
    font-size: var(--text-sm);
    color: var(--c-ink-subtle);
    text-align: center;
    line-height: 1.55;
  }

  @media (max-width: 560px) {
    .media-pair__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
