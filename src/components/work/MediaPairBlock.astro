---
interface Props {
  caption?: string;
  srcLeft?: string;
  srcRight?: string;
  altLeft?: string;
  altRight?: string;
  labelLeft?: string;
  labelRight?: string;
  aspectRatio?: string; /* e.g. "16/9" or "4/3" */
}

const {
  caption,
  srcLeft, srcRight,
  altLeft = '', altRight = '',
  labelLeft, labelRight,
  aspectRatio = '4/3',
} = Astro.props;
---

<figure class="media-pair">
  <div class="media-pair__grid">
    {[
      { src: srcLeft,  alt: altLeft,  label: labelLeft  },
      { src: srcRight, alt: altRight, label: labelRight },
    ].map(({ src, alt, label }) => (
      <div class="media-pair__frame" style={`aspect-ratio: ${aspectRatio}`}>
        {src ? (
          <img src={src} alt={alt} loading="lazy" />
        ) : (
          <div class="media-pair__placeholder" aria-hidden="true">
            <span class="label">Image</span>
          </div>
        )}
        {label && <span class="media-pair__label">{label}</span>}
      </div>
    ))}
  </div>

  {caption && (
    <figcaption class="media-pair__caption">{caption}</figcaption>
  )}
</figure>

<style>
  .media-pair {
    max-width: var(--w-content);
    margin-inline: auto;
    margin-block: var(--space-lg);
    padding-inline: var(--space-md);
  }

  .media-pair__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .media-pair__frame {
    position: relative;
    overflow: hidden;
    border-radius: 2px;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
  }

  .media-pair__frame img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .media-pair__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--c-surface-raised), var(--c-surface));
  }

  .media-pair__label {
    position: absolute;
    bottom: 0.75rem;
    left: 0.75rem;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 400;
    color: #fff;
    background: rgba(0,0,0,0.55);
    padding: 0.3em 0.6em;
    border-radius: 1px;
    backdrop-filter: blur(4px);
  }

  .media-pair__caption {
    margin-top: 0.9rem;
    font-size: var(--text-sm);
    color: var(--c-ink-subtle);
    text-align: center;
    line-height: 1.55;
  }

  @media (max-width: 560px) {
    .media-pair__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
