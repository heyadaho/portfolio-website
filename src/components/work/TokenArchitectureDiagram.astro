---
// No props — self-contained diagram
---
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@700&display=swap" rel="stylesheet" />

<figure class="token-diagram">

  <div class="token-diagram__svg-wrap">
    <svg width="100%" viewBox="0 0 680 300" role="img" xmlns="http://www.w3.org/2000/svg" aria-labelledby="tad-title tad-desc">
      <title id="tad-title">Three-tier token architecture</title>
      <desc id="tad-desc">Three horizontal bands stacked base to top: Core tokens at the bottom, Semantic tokens in the middle, Brand theme layer split into Trafalgar and Contiki at the top.</desc>
      <defs>
        <marker id="tad-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
          <path d="M2 1L8 5L2 9" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="tad-arrow-path"/>
        </marker>
      </defs>

      <!-- Brand theme: Trafalgar -->
      <rect class="tad-brand-trafalgar-rect" x="60" y="20" width="264" height="76" rx="6" stroke-width="0.5"/>
      <text class="tad-brand-trafalgar-label" x="80" y="51" font-size="13" font-weight="500" font-family="inherit">Trafalgar theme</text>
      <text class="tad-brand-trafalgar-meta" x="80" y="69" font-size="11" font-family="inherit">--brand-primary: #DC1D3C</text>
      <text class="tad-brand-trafalgar-meta" x="80" y="85" font-size="11" font-family="inherit">--color-text-on-brand: #000000</text>

      <!-- Brand theme: Contiki -->
      <rect class="tad-brand-contiki-rect" x="356" y="20" width="264" height="76" rx="6" stroke-width="0.5"/>
      <text class="tad-brand-contiki-label" x="376" y="51" font-size="13" font-weight="500" font-family="inherit">Contiki theme</text>
      <text class="tad-brand-contiki-meta" x="376" y="69" font-size="11" font-family="inherit">--brand-primary: #C5FF00</text>
      <text class="tad-brand-contiki-meta" x="376" y="85" font-size="11" font-family="inherit">--color-text-on-brand: #FFFFFF</text>

      <!-- Connector lines: semantic → brands -->
      <line x1="340" y1="120" x2="340" y2="110" class="tad-line"/>
      <line x1="192" y1="110" x2="488" y2="110" class="tad-line"/>
      <line x1="192" y1="110" x2="192" y2="96" class="tad-line" marker-end="url(#tad-arrow)"/>
      <line x1="488" y1="110" x2="488" y2="96" class="tad-line" marker-end="url(#tad-arrow)"/>

      <!-- Semantic tokens layer -->
      <rect class="tad-semantic-rect" x="60" y="120" width="560" height="68" rx="6" stroke-width="0.5"/>
      <text class="tad-semantic-label" x="80" y="148" font-size="13" font-weight="500" font-family="inherit">Semantic tokens</text>
      <text class="tad-semantic-meta" x="80" y="166" font-size="11" font-family="inherit">--btn-bg: var(--brand-primary) · --padding: var(--space-4) · --radius: var(--radius-sm)</text>

      <!-- Connector: core → semantic -->
      <line x1="340" y1="212" x2="340" y2="188" class="tad-line" marker-end="url(#tad-arrow)"/>

      <!-- Core tokens layer -->
      <rect class="tad-core-rect" x="60" y="212" width="560" height="68" rx="6" stroke-width="0.5"/>
      <text class="tad-core-label" x="80" y="240" font-size="13" font-weight="500" font-family="inherit">Core tokens</text>
      <text class="tad-core-meta" x="80" y="258" font-size="11" font-family="inherit">--color-red: #DC1D3C · --space-4: 16px · --radius-sm: 4px</text>
    </svg>
  </div>

  <p class="token-diagram__section-label">Same component, two brand themes</p>

  <div class="token-diagram__brand-grid">

    <div class="token-diagram__brand">
      <div class="token-diagram__brand-label">
        <span class="token-diagram__dot" style="background: #DC1D3C;"></span>
        <span>Trafalgar</span>
      </div>
      <div class="tour-card tour-card--trafalgar">
        <div class="tour-card__header">
          <span class="tour-card__region">Europe</span>
          <span class="tour-card__name">Classic Europe</span>
        </div>
        <div class="tour-card__body">
          <p class="tour-card__meta">14 days · From £3,490</p>
          <button class="tour-card__cta">View tour</button>
        </div>
      </div>
    </div>

    <div class="token-diagram__brand">
      <div class="token-diagram__brand-label">
        <span class="token-diagram__dot" style="background: #C5FF00;"></span>
        <span>Contiki</span>
      </div>
      <div class="tour-card tour-card--contiki">
        <div class="tour-card__header">
          <span class="tour-card__region">Europe</span>
          <span class="tour-card__name">European escape</span>
        </div>
        <div class="tour-card__body">
          <p class="tour-card__meta">7 days · From £1,290</p>
          <button class="tour-card__cta">View tour</button>
        </div>
      </div>
    </div>

  </div>

  <figcaption class="token-diagram__caption">Token architecture: one structure, unlimited brand expressions</figcaption>

</figure>

<style>
  .token-diagram {
    margin-block: var(--space-lg);
    border: 1px solid var(--c-border);
    border-radius: 2px;
    padding: 2rem;
    background: var(--c-surface);
    max-width: var(--w-text);
    margin-inline: auto;
  }

  .token-diagram__svg-wrap {
    max-width: 560px;
    margin-inline: auto;
  }

  /* ── SVG colour roles ── */

  .tad-core-rect   { fill: var(--c-surface-raised); stroke: var(--c-border-strong); }
  .tad-core-label  { fill: var(--c-ink); }
  .tad-core-meta   { fill: var(--c-ink-subtle); }

  .tad-semantic-rect  { fill: color-mix(in srgb, var(--c-accent) 8%, var(--c-surface)); stroke: color-mix(in srgb, var(--c-accent) 40%, transparent); }
  .tad-semantic-label { fill: var(--c-ink); }
  .tad-semantic-meta  { fill: var(--c-ink-subtle); }

  /* Trafalgar: red */
  .tad-brand-trafalgar-rect  { fill: #DC1D3C; stroke: #B81733; }
  .tad-brand-trafalgar-label { fill: #ffffff; }
  .tad-brand-trafalgar-meta  { fill: #FFAAB5; }

  /* Contiki: lime */
  .tad-brand-contiki-rect  { fill: #C5FF00; stroke: #A8DC00; }
  .tad-brand-contiki-label { fill: #1a1a1a; }
  .tad-brand-contiki-meta  { fill: #3a4a00; }

  .tad-line        { stroke: var(--c-border-strong); stroke-width: 1.5px; fill: none; }
  .tad-arrow-path  { stroke: var(--c-border-strong); }

  /* ── Cards ── */
  .token-diagram__section-label {
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #666666;
    margin-top: 1.5rem;
    margin-bottom: 0.9rem;
  }

  .token-diagram__brand-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .token-diagram__brand-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
  }

  .token-diagram__dot {
    width: 8px;
    height: 8px;
    border-radius: 2px;
    display: inline-block;
    flex-shrink: 0;
  }

  .token-diagram__brand-label span:last-child {
    font-size: var(--text-xs);
    font-weight: 500;
    color: #666666;
    letter-spacing: 0.04em;
  }

  .tour-card {
    border-radius: 4px;
    overflow: hidden;
  }

  .tour-card__header {
    padding: 1rem 1.1rem;
  }

  .tour-card__region {
    display: block;
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }

  .tour-card__name {
    display: block;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .tour-card__body {
    padding: 0.9rem 1.1rem;
    background: #ffffff;
  }

  .tour-card__meta {
    font-size: 0.75rem;
    color: #1a1a1a !important;
    margin-bottom: 0.75rem;
  }

  .tour-card__cta {
    border: none;
    padding: 0.5rem;
    border-radius: 3px;
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    width: 100%;
    font-family: var(--font-body);
  }

  /* Trafalgar: red, white text, Noto Sans 700 */
  .tour-card--trafalgar                    { border: 1px solid rgba(220, 29, 60, 0.3); font-family: 'Noto Sans', sans-serif; font-weight: 700; }
  .tour-card--trafalgar .tour-card__header { background: #DC1D3C; }
  .tour-card--trafalgar .tour-card__region { color: rgba(255,255,255,0.6); }
  .tour-card--trafalgar .tour-card__name   { color: #ffffff; font-family: 'Noto Sans', sans-serif; font-weight: 700; }
  .tour-card--trafalgar .tour-card__meta   { color: #414141 !important; }
  .tour-card--trafalgar .tour-card__cta    { background: #DC1D3C; color: #ffffff; font-family: 'Noto Sans', sans-serif; font-weight: 700; }

  /* Contiki: lime, black text, Soleil 700 */
  .tour-card--contiki                    { border: 1px solid rgba(197, 255, 0, 0.3); font-family: 'Soleil', 'Futura', 'Century Gothic', sans-serif; font-weight: 700; }
  .tour-card--contiki .tour-card__header { background: #C5FF00; }
  .tour-card--contiki .tour-card__region { color: rgba(0,0,0,0.5); }
  .tour-card--contiki .tour-card__name   { color: #000000; font-family: 'Soleil', 'Futura', 'Century Gothic', sans-serif; font-weight: 700; }
  .tour-card--contiki .tour-card__cta    { background: #C5FF00; color: #000000; font-family: 'Soleil', 'Futura', 'Century Gothic', sans-serif; font-weight: 700; }

  .token-diagram__caption {
    margin-top: 1rem;
    font-size: var(--text-sm);
    color: #666666;
    text-align: center;
    line-height: 1.55;
  }

  @media (max-width: 480px) {
    .token-diagram__brand-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
