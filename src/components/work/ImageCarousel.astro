---
interface Image {
  src: string;
  caption?: string;
}

interface Props {
  images: Image[];
}

const { images } = Astro.props;
if (!images || images.length === 0) return;

const id = `carousel-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="carousel" id={id} aria-label="Image carousel" role="region">
  <div class="carousel__track-wrap">
    <ul class="carousel__track" aria-live="polite">
      {images.map((img, i) => (
        <li class="carousel__slide" aria-hidden={i !== 0 ? 'true' : 'false'} data-index={i}>
          <img
            src={img.src}
            alt={img.caption ?? ''}
            class="carousel__img"
            loading={i === 0 ? 'eager' : 'lazy'}
          />
        </li>
      ))}
    </ul>

    {images.length > 1 && (
      <>
        <button class="carousel__btn carousel__btn--prev" aria-label="Previous image" data-dir="-1">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M10 2L4 8L10 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="carousel__btn carousel__btn--next" aria-label="Next image" data-dir="1">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M6 2L12 8L6 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </>
    )}
  </div>

  <div class="carousel__footer">
    <p class="carousel__caption" aria-live="polite">
      {images[0].caption ?? ''}
    </p>
    {images.length > 1 && (
      <div class="carousel__dots" role="tablist" aria-label="Select image">
        {images.map((_, i) => (
          <button
            class:list={['carousel__dot', { 'carousel__dot--active': i === 0 }]}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-label={`Image ${i + 1} of ${images.length}`}
            data-index={i}
          />
        ))}
      </div>
    )}
  </div>
</div>

<script define:vars={{ id, images }}>
  const root = document.getElementById(id);
  if (!root) return;

  const track = root.querySelector('.carousel__track');
  const slides = root.querySelectorAll('.carousel__slide');
  const caption = root.querySelector('.carousel__caption');
  const dots = root.querySelectorAll('.carousel__dot');
  const btnPrev = root.querySelector('.carousel__btn--prev');
  const btnNext = root.querySelector('.carousel__btn--next');

  let current = 0;

  function goTo(index) {
    slides[current].setAttribute('aria-hidden', 'true');
    dots[current]?.classList.remove('carousel__dot--active');
    dots[current]?.setAttribute('aria-selected', 'false');

    current = (index + slides.length) % slides.length;

    slides[current].setAttribute('aria-hidden', 'false');
    dots[current]?.classList.add('carousel__dot--active');
    dots[current]?.setAttribute('aria-selected', 'true');
    track.style.transform = `translateX(-${current * 100}%)`;

    if (caption) {
      caption.textContent = images[current].caption ?? '';
    }
  }

  btnPrev?.addEventListener('click', () => goTo(current - 1));
  btnNext?.addEventListener('click', () => goTo(current + 1));

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => goTo(i));
  });

  // Keyboard navigation
  root.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') goTo(current - 1);
    if (e.key === 'ArrowRight') goTo(current + 1);
  });

  // Touch / swipe
  let startX = 0;
  track.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend', (e) => {
    const diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) goTo(diff > 0 ? current + 1 : current - 1);
  }, { passive: true });
</script>

<style>
  .carousel {
    width: 100%;
    max-width: min(var(--w-content), 100%);
    margin-inline: auto;
    margin-block: var(--space-lg);
  }

  /* Track */
  .carousel__track-wrap {
    position: relative;
    overflow: hidden;
    border-radius: 3px;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
  }

  .carousel__track {
    display: flex;
    list-style: none;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  .carousel__slide {
    flex: 0 0 100%;
    width: 100%;
    aspect-ratio: 16 / 9;
  }

  .carousel__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: var(--c-bg);
  }

  /* Nav buttons */
  .carousel__btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: 50%;
    color: var(--c-ink-mid);
    cursor: pointer;
    transition:
      background var(--dur-fast),
      border-color var(--dur-fast),
      color var(--dur-fast);
    z-index: 1;
  }

  .carousel__btn--prev { left: 0.75rem; }
  .carousel__btn--next { right: 0.75rem; }

  .carousel__btn:hover {
    background: var(--c-bg);
    border-color: var(--c-border-strong);
    color: var(--c-ink);
  }

  /* Footer: caption + dots */
  .carousel__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.9rem;
    min-height: 1.6rem;
  }

  .carousel__caption {
    font-size: var(--text-sm);
    color: var(--c-ink-subtle);
    font-weight: 300;
    line-height: 1.5;
    flex: 1;
  }

  /* Dots */
  .carousel__dots {
    display: flex;
    gap: 0.4rem;
    flex-shrink: 0;
  }

  .carousel__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--c-border-strong);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background var(--dur-fast), transform var(--dur-fast);
  }

  .carousel__dot--active {
    background: var(--c-ink-mid);
    transform: scale(1.3);
  }
</style>
