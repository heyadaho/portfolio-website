---
interface Props {
  caption?: string;
  srcLeft?: string;
  srcMid?: string;
  srcRight?: string;
  altLeft?: string;
  altMid?: string;
  altRight?: string;
}

const { caption, srcLeft, srcMid, srcRight, altLeft = '', altMid = '', altRight = '' } = Astro.props;
const groupId = `triple-${Math.random().toString(36).slice(2, 8)}`;
---

<figure class="media-triple">
  <div class="media-triple__grid">
    {[
      { src: srcLeft, alt: altLeft },
      { src: srcMid,  alt: altMid  },
      { src: srcRight, alt: altRight },
    ].map(({ src, alt }) => (
      <div class="media-triple__frame">
        {src ? (
          <button class="media-triple__btn" data-lightbox data-group={groupId} aria-label={`Expand: ${alt}`}>
            <img src={src} alt={alt} loading="lazy" decoding="async" />
            <span class="media-triple__zoom" aria-hidden="true">&#x2922;</span>
          </button>
        ) : (
          <div class="media-triple__placeholder" aria-hidden="true">
            <span class="label">Image</span>
          </div>
        )}
      </div>
    ))}
  </div>

  {caption && (
    <figcaption class="media-triple__caption">{caption}</figcaption>
  )}
</figure>

<style>
  .media-triple {
    max-width: var(--w-content);
    margin-inline: auto;
    margin-block: var(--space-lg);
    padding-inline: var(--space-md);
  }

  .media-triple__grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
  }

  .media-triple__frame {
    overflow: hidden;
    border-radius: 2px;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
  }

  .media-triple__btn {
    all: unset;
    display: block;
    width: 100%;
    cursor: zoom-in;
    position: relative;
  }

  .media-triple__btn img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.2s;
  }

  .media-triple__btn:hover img {
    opacity: 0.85;
  }

  .media-triple__zoom {
    position: absolute;
    bottom: 0.5rem;
    right: 0.6rem;
    font-size: 1.1rem;
    color: #fff;
    opacity: 0;
    transition: opacity 0.2s;
    text-shadow: 0 1px 4px rgba(0,0,0,0.6);
    pointer-events: none;
  }

  .media-triple__btn:hover .media-triple__zoom {
    opacity: 1;
  }

  .media-triple__placeholder {
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--c-surface-raised), var(--c-surface));
  }

  .media-triple__caption {
    margin-top: 0.9rem;
    font-size: var(--text-sm);
    color: var(--c-ink-subtle);
    text-align: center;
    line-height: 1.55;
  }

  @media (max-width: 640px) {
    .media-triple__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
