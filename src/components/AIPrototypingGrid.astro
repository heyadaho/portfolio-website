---
import AIPrototypingCard from './AIPrototypingCard.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('ai');
const articles = entries
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .map(entry => ({
    title:       entry.data.title,
    company:     entry.data.company,
    role:        entry.data.role,
    year:        entry.data.year,
    description: entry.data.summary,
    tags:        entry.data.tags ?? [],
    href:           `/ai/${entry.id}`,
    comingSoon:     false,
    image:          entry.data.heroImages?.[0]?.src ?? entry.data.image,
    images:         entry.data.heroImages,
    workInProgress: entry.data.workInProgress ?? false,
  }));
---

<section class="ai-section section" id="ai-prototyping">
  <div class="container">

    <div class="ai-section__header">
      <span class="label">AI Prototyping</span>
    </div>

    <div class="ai-grid">
      {articles.map(p => (
        <AIPrototypingCard
          title={p.title}
          company={p.company}
          role={p.role}
          year={p.year}
          description={p.description}
          tags={p.tags}
          href={p.href}
          comingSoon={p.comingSoon}
          image={p.image}
          images={p.images}
          workInProgress={p.workInProgress}
        />
      ))}
    </div>

  </div>
</section>

<style>
  .ai-section__header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--c-border);
  }

  .ai-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .ai-grid {
      gap: 1.25rem;
    }
  }
</style>
