---

<section class="contact section" id="contact">
  <div class="container">

    <div class="contact__header" data-reveal>
      <span class="label">Contact</span>
    </div>

    <a href="mailto:hello@edlake.co" class="contact__link" data-reveal style="--reveal-i: 1">
      <span class="contact__headline">Let's talk<span class="contact__stop">.</span></span>
      <span class="contact__meta">
        <span class="contact__email">hello@edlake.co</span>
        <span class="contact__arrow" aria-hidden="true">→</span>
      </span>
    </a>

  </div>
</section>

<style>
  .contact__header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--c-border);
  }

  .contact__link {
    display: inline-flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact__headline {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--c-ink);
    position: relative;
    align-self: flex-start;
  }

  .contact__stop {
    color: var(--c-accent);
  }

  /* Underline grows in from the left on hover */
  .contact__headline::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -0.08em;
    width: 100%;
    height: 1px;
    background: var(--c-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--dur-slow) var(--ease-expo);
  }

  .contact__link:hover .contact__headline::after {
    transform: scaleX(1);
  }

  .contact__meta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: var(--text-sm);
    color: var(--c-ink-mid);
    transition: color var(--dur-fast);
  }

  .contact__arrow {
    color: var(--c-ink-subtle);
    transition: transform var(--dur-fast), color var(--dur-fast);
  }

  .contact__link:hover .contact__meta {
    color: var(--c-ink);
  }

  .contact__link:hover .contact__arrow {
    transform: translateX(3px);
    color: var(--c-accent);
  }
</style>
